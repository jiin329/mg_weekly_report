# ---------------------------------------------------------------------------
# weekly-report-chat — environment configuration example
#
# Copy this file to `.env` (in the project root) and fill in the values before
# starting the Desktop_App. The backend loads these on startup.
#
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
# ---------------------------------------------------------------------------

# ===========================================================================
# LLM provider selection
# ===========================================================================
# Selects HOW the app connects to an LLM. It does not change any app behavior
# beyond the connection. Supported values:
#   openai   (option A, default) — OpenAI-compatible /chat/completions endpoint
#   bedrock  (option B)          — Amazon Bedrock (converse API)
# Leave unset to default to `openai`.
LLM_PROVIDER=openai

# ===========================================================================
# Option A — OpenAI-compatible provider (LLM_PROVIDER=openai)
# ===========================================================================
# Required when LLM_PROVIDER=openai. The backend HALTS startup if either is
# missing/empty and reports each missing variable by name (Req 10.6, 11.9).

# API key sent as `Authorization: Bearer <key>`. REQUIRED (must not be empty).
LLM_API_KEY=your_api_key_here

# Base endpoint URL. REQUIRED (must not be empty).
# Example: https://api.openai.com/v1
LLM_ENDPOINT=https://api.openai.com/v1

# Optional model name override for the OpenAI-compatible request.
# Defaults to gpt-4o-mini if unset.
# LLM_MODEL=gpt-4o-mini

# ===========================================================================
# Option B — Amazon Bedrock provider (LLM_PROVIDER=bedrock)
# ===========================================================================
# NOTE: Bedrock does NOT authenticate with a single API key. It uses AWS
# credentials via boto3's standard chain, plus a region and a model id.
# Install the extra dependency first:  pip install boto3
#
# Required when LLM_PROVIDER=bedrock:
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
#
# AWS region for the bedrock-runtime client (AWS_DEFAULT_REGION also accepted;
# boto3 may also read it from your shared AWS config):
# AWS_REGION=us-east-1
#
# Credentials — provide ONE of the following (resolved by boto3):
#   1) Static keys:
#      AWS_ACCESS_KEY_ID=...
#      AWS_SECRET_ACCESS_KEY=...
#      # AWS_SESSION_TOKEN=...        (only for temporary credentials)
#   2) A named profile from ~/.aws/credentials:
#      AWS_PROFILE=my-profile
#   3) A Bedrock API key (bearer token):
#      AWS_BEARER_TOKEN_BEDROCK=...

# ===========================================================================
# Backend (shared by both providers)
# ===========================================================================
# Local loopback port for the backend FastAPI server. OPTIONAL.
# Defaults to 8756 if unset. Frontend <-> Backend traffic stays on 127.0.0.1.
# If this port is already in use, the backend halts and reports the conflict
# (Requirement 10.8).
BACKEND_PORT=8756
