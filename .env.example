# ---------------------------------------------------------------------------
# weekly-report-chat — environment configuration example
#
# Copy this file to `.env` (in the project root) and fill in the values before
# starting the Desktop_App. The backend loads these on startup.
#
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
#
# The backend HALTS startup if LLM_API_KEY or LLM_ENDPOINT is missing/empty and
# reports each missing variable by name (Requirements 10.6, 11.9).
# ---------------------------------------------------------------------------

# API key for the external LLM service. REQUIRED (must not be empty).
LLM_API_KEY=

# Base endpoint URL of the external LLM service. REQUIRED (must not be empty).
# Example: https://api.your-llm-provider.com/v1
LLM_ENDPOINT=

# Local loopback port for the backend FastAPI server. OPTIONAL.
# Defaults to 8756 if unset. Frontend <-> Backend traffic stays on 127.0.0.1.
# If this port is already in use, the backend halts and reports the conflict
# (Requirement 10.8).
BACKEND_PORT=8756
