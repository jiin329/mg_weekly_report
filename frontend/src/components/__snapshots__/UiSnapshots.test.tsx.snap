exports[`Chat_UI snapshots > LoadingIndicator — report generation wait (Req 4.4) 1`] = `
<div>
  <div
    aria-live="polite"
    class="loading-indicator"
    role="status"
  >
    <span
      aria-hidden="true"
      class="loading-indicator__spinner"
    />
    <span
      class="loading-indicator__label"
    >
      주간보고를 생성하고 있습니다...
    </span>
  </div>
</div>
`;

exports[`Chat_UI snapshots > MessageBubble — user vs system alignment/color (Req 2.1, 2.2) 1`] = `
<div>
  <div
    class="bubble-row bubble-row--user"
  >
    <div
      class="bubble bubble--user"
    >
      <p
        class="bubble__content"
      >
        이번 주 결제 모듈 리팩터링을 완료했습니다.
      </p>
      <time
        class="bubble__time"
        datetime="2024-06-03T09:30:00.000Z"
      >
        2024. 06. 03. PM 06:30
      </time>
    </div>
  </div>
  <div
    class="bubble-row bubble-row--system"
  >
    <div
      class="bubble bubble--system"
    >
      <p
        class="bubble__content"
      >
        생성된 주간보고입니다.
      </p>
      <time
        class="bubble__time"
        datetime="2024-06-03T09:30:00.000Z"
      >
        2024. 06. 03. PM 06:30
      </time>
    </div>
  </div>
</div>
`;

