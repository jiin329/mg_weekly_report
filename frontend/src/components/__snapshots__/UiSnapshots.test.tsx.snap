exports[`Chat_UI snapshots > ReportCard — four sections and copy button (Req 5.4, 5.5) 1`] = `
<div>
  <section
    aria-label="주간보고"
    class="report-card"
  >
    <header
      class="report-card__header"
    >
      <h2
        class="report-card__title"
      >
        주간보고
      </h2>
      <button
        class="report-card__copy"
        type="button"
      >
        복사
      </button>
    </header>
    <dl
      class="report-card__sections"
    >
      <div
        class="report-card__section"
      >
        <dt
          class="report-card__label"
        >
          작성일
        </dt>
        <dd
          class="report-card__value"
        >
          2025-06-13
        </dd>
      </div>
      <div
        class="report-card__section"
      >
        <dt
          class="report-card__label"
        >
          금주 업무 실적
        </dt>
        <dd
          class="report-card__value"
        >
          결제 모듈 리팩터링 완료
        </dd>
      </div>
      <div
        class="report-card__section"
      >
        <dt
          class="report-card__label"
        >
          차주 업무 계획
        </dt>
        <dd
          class="report-card__value"
        >
          알림 서비스 설계 착수
        </dd>
      </div>
      <div
        class="report-card__section"
      >
        <dt
          class="report-card__label"
        >
          이슈 및 건의사항
        </dt>
        <dd
          class="report-card__value"
        >
          테스트 환경 리소스 부족
        </dd>
      </div>
    </dl>
  </section>
</div>
`;

exports[`Chat_UI snapshots > RoomList — active/closed distinction and selection (Req 7.1–7.4) 1`] = `
<div>
  <nav
    aria-label="채팅방 목록"
    class="room-list"
  >
    <ul
      class="room-list__items"
    >
      <li>
        <button
          aria-current="true"
          class="room room--active room--selected"
          type="button"
        >
          <span
            class="room__title"
          >
            주간보고
          </span>
          <span
            class="room__date"
          >
            2024. 3. 11.
          </span>
          <span
            class="room__status room__status--active"
          >
            진행 중
          </span>
          <span
            class="room__id"
          >
            r-active
          </span>
        </button>
      </li>
      <li>
        <button
          class="room room--closed"
          type="button"
        >
          <span
            class="room__title"
          >
            주간보고
          </span>
          <span
            class="room__date"
          >
            2024. 3. 4.
          </span>
          <span
            class="room__status room__status--closed"
          >
            완료
          </span>
          <span
            class="room__id"
          >
            r-closed
          </span>
        </button>
      </li>
    </ul>
  </nav>
</div>
`;
